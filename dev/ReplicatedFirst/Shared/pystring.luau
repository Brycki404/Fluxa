--- @param s string
--- @return string
function pystring.capitalize(s: string): string
	if #s < 1 then
		return s
	end
	local s1 = string.sub(s, 1, 1)
	local s2 = string.sub(s, 2)
	return string.format("%s%s", string.upper(s1), s2)
