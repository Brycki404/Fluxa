--- Capitalize all of words in `s`.
--- --
--- @param s string
--- @return string
function pystring.title(s: string): string
	if #s < 1 then
		return s
	end

	local ss = split(s, " ")
	for i = 1, #ss do
		ss[i] = capitalize(ss[i])
	end
	return concat(ss, " ")
end

--- Capitalize line by line all the lines in `s`.
--- --
--- @param s string
--- @return string
function pystring.capwords(s: string): string
	local lines = split(s, "\n")
	local rLines = {}
	for i, line in ipairs(lines) do
		local rWords = {}
		local words = split(line, " ")
		for j, word in ipairs(words) do
			rWords[j] = capitalize(word)
		end
		rLines[i] = concat(rWords, " ")
	end
	return concat(rLines, "\n")
end

--- Justify `s` by left with `len` copies of `ch`.
--- --
--- @param s string
--- @param len integer
--- @param ch? string # Default " "
--- @return string
function pystring.ljust(s: string, len: number, ch: string?): string
	ch = ch or " "
	if #ch ~= 1 then
		error(string.format("pad string master a single word, not %s", tostring(ch)))
	end
	local delta = len - #s
	if delta > 0 then
		local pad = rep(ch, delta)
		return string.format("%s%s", pad, s)
	else
		return s
	end
end

--- Justify `s` by right with `len` copies of `ch`.
--- --
--- @param s string
--- @param len integer
--- @param ch? string # Default " "
--- @return string
function pystring.rjust(s: string, len: number, ch: string?): string
	ch = ch or " "
	if #ch ~= 1 then
		error(string.format("pad string master a single word, not %s", tostring(ch)))
	end
	local delta = len - #s
	if delta > 0  then
		local pad = rep(ch, delta)
		return string.format("%s%s", s, pad)
	else
		return s
	end
end

--- Center `s` lines with `len` copies of `ch` in the longest line.
--- --
--- @param s string
--- @param len integer
--- @param ch? string # Default " "
--- @return string
function pystring.center(s: string, len: number, ch: string?): string
	ch = ch or " "
	if #ch ~= 1 then
		error(string.format("pad string master a single word, not %s", tostring(ch)))
	end
	local delta = len - #s
	if delta > 0 then
		local left = floor(delta / 2)
		local right = delta - left

		local res = {rep(ch, left), s, rep(ch, right)}
		return concat(res)
	else
		return s
	end
end

