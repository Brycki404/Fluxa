--- Remove first `chars` string of `s`. 
--- --
--- @param s string
--- @param chars string
--- @return string
function pystring.lstrip(s: string, chars: string): string
	local patten = concat({"^", setupPatten(chars), "+"})
	local _, ends = string_find(s, patten)
	if ends then
		return string.sub(s, ends + 1, -1)
	else
		return s
	end
end

--- Remove last `chars` string of `s`.
--- --
--- @param s string
--- @param chars string
--- @return string
function pystring.rstrip(s: string, chars: string): string
	local patten = string.format("%s%s", setupPatten(chars), "+$")
	local last = string_find(s, patten)
	if last then
		return string.sub(s, 1, last - 1)
	else
		return s
	end
end

